#include <stdio.h>
#include <stdlib.h>

int main() 
{
	printf("We consider that the day on 01/01/01 was monday, this program will find the day on 1st January of any year");
	printf("\nEnter the year:");
	int year;
	scanf("%d",&year);
	year=year-2001;
	if(year<1)
	{
		year=year*(-1);
		int days,lp_year;
		lp_year=year/4;
		year=year-lp_year;
		year=year*365;
		lp_year=lp_year*366;
		days=lp_year+year;
		days=days%7;
		if(days==6)
			printf("The day is monday");
		else if(days==5)
			printf("The day is tuesday");
		else if(days==4)
			printf("The day is wednesday");
		else if(days==3)
			printf("The day is thursday");
		else if(days==2)
			printf("The day is friday");
		else if(days==1)
			printf("The day is saturday");
		else if(days==0)	
			printf("The day is sunday");
	}
	else
	{
		int days,lp_year;
		lp_year=year/4;
		year=year-lp_year;
		year=year*365;
		lp_year=lp_year*366;
		days=lp_year+year;
		days=days%7;
		if(days==0)
			printf("The day is monday");
		else if(days==1)
			printf("The day is tuesday");
		else if(days==2)
			printf("The day is wednesday");
		else if(days==3)
			printf("The day is thursday");
		else if(days==4)
			printf("The day is friday");
		else if(days==5)
			printf("The day is saturday");
		else if(days==6)	
			printf("The day is sunday");
	}
}
