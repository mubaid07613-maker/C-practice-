/*This is a simple c-program to tackle input,output and conditional functions*/
#include <stdio.h>
#include <stdlib.h>

int main() 
{
	int num;
	printf("This program will take a five-digit number from you and reverse it,find the sum of the digits and\nif the number is equal to or less then 88888, it will also increment by 1 in each digit.");
	printf("\n\nEnter a five digit number:");
	scanf("%d",&num);
	if(num>=10000)
	{
	int num1,num2,num3,num4,num5,num6,num7,num8,total;
	num1=num%10;
	num2=num/10;
	num3=num2%10;
	num4=num/100;
	num5=num4%10;
	num6=num/1000;
	num7=num6%10;
	num8=num/10000;
	printf("\nThe reversed form is %d%d%d%d%d",num1,num3,num5,num7,num8);
	total=num1+num3+num5+num7+num8;
	printf("\nthe sum of the digits is %d",total);
	printf("\nIncremented value is %d",num+11111);
	}
	else
	{
		printf("you didnt give a five digit number");
	}
	
	
}
